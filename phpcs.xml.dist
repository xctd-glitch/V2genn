<?xml version="1.0"?>
<ruleset name="notrackng">
    <description>PSR-12 coding standard</description>

    <file>src</file>
    <file>redirect</file>
    <file>admin</file>
    <file>bootstrap</file>
    <file>module</file>
    <file>ops</file>
    <file>user</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/data/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>

    <rule ref="PSR12"/>
</ruleset>
