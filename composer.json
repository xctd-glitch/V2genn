{
    "name": "local/notrackng",
    "description": "notrackng quality gate",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "maxmind-db/reader": "^1.13.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit --configuration phpunit.xml.dist --fail-on-warning",
        "stan": "@php vendor/bin/phpstan analyse --configuration phpstan.neon.dist --memory-limit=1G",
        "cs": "@php vendor/bin/phpcs --standard=phpcs.xml.dist",
        "fixer:check": "@php vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --using-cache=no",
        "ops:indexes": "@php ops/ensure_mysql_hot_indexes.php --json",
        "build:production": "@php ops/build_production_zip.php"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
