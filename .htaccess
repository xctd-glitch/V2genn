# ── Blokir directory listing ──
Options -Indexes

# ── Proteksi folder data/ (DB + config) ──
<IfModule mod_rewrite.c>
    RewriteEngine On

    # ── Blokir direktori non-public saat app dipasang langsung di docroot shared host ──
    RewriteRule ^metrics$ metrics.php [L,QSA]
    RewriteRule ^healthz$ metrics.php [L,QSA]
    RewriteRule ^(?:bootstrap|cgi-bin|ops|src|vendor|module)/ - [F,L,NC]

    # ── Blokir data/ ──
    RewriteRule ^data/ - [F,L]

    # ── Blokir build/ (ZIP produksi tidak boleh dapat diakses via HTTP) ──
    RewriteRule ^build/ - [F,L]

    # ── Blokir file sensitif di root yang tetap ikut terpaket saat deploy ──
    RewriteRule ^(?:composer\.(?:json|lock)|php\.ini|\.user\.ini)$ - [F,L,NC]

    # ── Root → admin dashboard ──
    RewriteRule ^$ admin/index.php [L,QSA]
    RewriteRule ^index\.php$ admin/index.php [L,QSA]

    # ── API endpoints ──
    RewriteRule ^handler\.php$ admin/handler.php [L,QSA]
    RewriteRule ^ogimg\.php$ redirect/ogimg.php [L,QSA]
    # /go.php is the no-JS / meta-refresh fallback target emitted by the
    # redirect loader (see goTrackerFallbackUrl in redirect/go.php). Without
    # this route, clients without JS hit 404 on the fallback link.
    RewriteRule ^go\.php$ redirect/go.php [L,QSA]

    # ── Pretty URL: /gen → user shortlink manager ──
    RewriteRule ^gen$ user/sl.php [L,QSA]

    # ── Pretty URL: /redirect-engine → admin redirect engine ──
    RewriteRule ^redirect-engine$ admin/redirect-engine.php [L,QSA]

    # ── Pretty URL: /postback → postback receiver ──
    RewriteRule ^postback$ redirect/recv.php [L,QSA]

    # ── Pretty URL: /privacy & /terms ──
    RewriteRule ^privacy$ privacy.php [L]
    RewriteRule ^terms$ terms.php [L]

    # ── Pretty URL: /{slug} → redirect handler ──
    # Lewati file/folder yang sudah ada
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # Lewati assets dan folder kategori
    RewriteCond %{REQUEST_URI} !^/(assets|data|admin|user|redirect|module)/
    RewriteCond %{REQUEST_URI} !^/(sw\.js|manifest\.json|favicon)
    # Match slug: 1–30 karakter alphanumeric/dash/underscore
    RewriteRule ^([a-zA-Z0-9_-]{1,30})$ redirect/go.php?s=$1 [L,QSA]
</IfModule>
<DirectoryMatch "data">
    Order allow,deny
    Deny from all
</DirectoryMatch>

# ── Blokir file sensitif di root ──
# NOTE: .txt di-allow secara eksplisit untuk robots.txt/ads.txt/humans.txt/security.txt
# supaya crawler dan social scraper (facebookexternalhit, Twitterbot, dll.)
# bisa ambil metadata dengan normal.
<FilesMatch "\.(env|log|bak|sql|sh|sqlite|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>
<FilesMatch "^(config\.json|production\.zip|security\.php|blocklist\.txt|PRODUCTION-PACKAGE\.txt|DEPLOY-CPANEL\.txt)$">
    Order allow,deny
    Deny from all
</FilesMatch>
<FilesMatch "\.(md)$">
    Order allow,deny
    Deny from all
</FilesMatch>
<FilesMatch "^install\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>
<FilesMatch "^(composer\.(json|lock)|php\.ini|\.user\.ini)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── PWA: MIME types ──
<IfModule mod_mime.c>
    AddType application/manifest+json  .webmanifest
    AddType application/json           .json
    AddType image/png                  .png
    AddType image/x-icon               .ico
</IfModule>

# ── Cache: assets statis (1 minggu) ──
<FilesMatch "\.(css|js|png|ico|woff2?)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=604800, immutable"
    </IfModule>
</FilesMatch>

# ── Cache: manifest & SW (no-cache agar update cepat) ──
<FilesMatch "^(manifest\.json|sw\.js)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </IfModule>
</FilesMatch>

# ── Security headers ──
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── PHP settings ──
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>
<IfModule mod_php7.c>
    php_value opcache.revalidate_freq 60
</IfModule>
<IfModule mod_php8.c>
    php_value opcache.revalidate_freq 60
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “alt-php83” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-alt-php83 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

